---
interface Experience {
	sector: string;
	companies: string;
	role: string;
	period: string;
	description: string;
	stack: string[];
	iconType: 'banking' | 'investment' | 'automotive' | 'hrtech' | 'fintech' | 'telecom';
}

const experiences: Experience[] = [
	{
		sector: "Banking Platform",
		companies: "Commerzbank",
		role: "Senior Backend Engineer",
		period: "2024 — Present",
		description: "Building next-gen loan pricing & deal processing platform (LEAP). Designing data persistence layers and core calculation modules.",
		stack: ["Kotlin", "Java", "Spring Boot", "GCP", "Kubernetes", "Kafka", "MongoDB"],
		iconType: "banking"
	},
	{
		sector: "Investment Tech",
		companies: "Bondster (P2P Lending)",
		role: "Senior Java Developer",
		period: "2023 — 2024",
		description: "Optimizing transaction core for investment process stability. Microservices architecture with reactive patterns.",
		stack: ["Java", "Spring", "Scala Akka", "AWS", "Kubernetes", "React"],
		iconType: "investment"
	},
	{
		sector: "Automotive Digital",
		companies: "Škoda Auto",
		role: "Backend Developer",
		period: "2023",
		description: "Refactoring RefCar sales system for dealers and employees. Streamlined DevOps practices.",
		stack: ["Java", "IBM WebSphere", "TFS"],
		iconType: "automotive"
	},
	{
		sector: "HR Tech Platform",
		companies: "Monster.com / Jobs.com",
		role: "Software Engineer",
		period: "2020 — 2023",
		description: "Building secure backend microservices for user profiles and identity management at scale.",
		stack: ["Java", "Spring Boot", "AWS", "Auth0", "DynamoDB", "Kubernetes"],
		iconType: "hrtech"
	},
	{
		sector: "Lending FinTech",
		companies: "4finance / LinkSoft",
		role: "Team Lead & Senior Developer",
		period: "2014 — 2020",
		description: "Full platform migration to modern microservices. Team leadership, client communication, delivery management.",
		stack: ["Java EE", "Spring Cloud", "Vaadin", "Jenkins", "Grafana"],
		iconType: "fintech"
	},
	{
		sector: "Telecom & Enterprise",
		companies: "Ericsson, Telenor, Telefónica O2",
		role: "Developer & Analyst",
		period: "2006 — 2014",
		description: "High-throughput systems for telco operators. LDAP adapters, subscriber data aggregation, provisioning systems.",
		stack: ["Java", "Netty", "Cassandra", "Spring", "Oracle", "Solaris"],
		iconType: "telecom"
	}
];
---

<section id="experience">
	<div class="section-header">
		<h2 class="section-title">Professional Journey</h2>
		<div class="title-accent"></div>
	</div>
	<p class="section-description">
		15+ years building enterprise software across banking, fintech, automotive, and telecom
	</p>
	<div class="experience-timeline">
		{experiences.map((exp, index) => (
			<div class="experience-card" data-index={index}>
				<div class="card-icon-wrapper">
					{exp.iconType === 'banking' && (
						<svg class="sector-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
							<rect x="4" y="38" width="40" height="4" rx="1" fill="currentColor" opacity="0.3"/>
							<rect x="6" y="18" width="6" height="20" fill="currentColor" opacity="0.6"/>
							<rect x="16" y="18" width="6" height="20" fill="currentColor" opacity="0.8"/>
							<rect x="26" y="18" width="6" height="20" fill="currentColor" opacity="0.6"/>
							<rect x="36" y="18" width="6" height="20" fill="currentColor" opacity="0.4"/>
							<path d="M24 4L4 16H44L24 4Z" fill="currentColor"/>
						</svg>
					)}
					{exp.iconType === 'investment' && (
						<svg class="sector-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M8 40L18 28L26 34L40 16" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
							<circle cx="40" cy="16" r="4" fill="currentColor"/>
							<path d="M8 44H44" stroke="currentColor" stroke-width="2" opacity="0.3"/>
							<path d="M4 40V12" stroke="currentColor" stroke-width="2" opacity="0.3"/>
						</svg>
					)}
					{exp.iconType === 'automotive' && (
						<svg class="sector-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M8 28L12 18H36L40 28" stroke="currentColor" stroke-width="2.5" fill="none"/>
							<rect x="6" y="28" width="36" height="10" rx="2" fill="currentColor" opacity="0.6"/>
							<circle cx="14" cy="38" r="4" fill="currentColor"/>
							<circle cx="34" cy="38" r="4" fill="currentColor"/>
							<rect x="18" y="20" width="12" height="6" rx="1" fill="currentColor" opacity="0.3"/>
						</svg>
					)}
					{exp.iconType === 'hrtech' && (
						<svg class="sector-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
							<circle cx="24" cy="14" r="8" fill="currentColor" opacity="0.8"/>
							<path d="M10 42C10 34.268 16.268 28 24 28C31.732 28 38 34.268 38 42" stroke="currentColor" stroke-width="3" fill="none"/>
							<circle cx="38" cy="18" r="5" fill="currentColor" opacity="0.4"/>
							<circle cx="10" cy="18" r="5" fill="currentColor" opacity="0.4"/>
						</svg>
					)}
					{exp.iconType === 'fintech' && (
						<svg class="sector-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
							<rect x="8" y="12" width="32" height="24" rx="3" stroke="currentColor" stroke-width="2.5" fill="none"/>
							<path d="M8 20H40" stroke="currentColor" stroke-width="2" opacity="0.5"/>
							<rect x="12" y="28" width="10" height="4" rx="1" fill="currentColor" opacity="0.6"/>
							<circle cx="34" cy="30" r="4" fill="currentColor" opacity="0.8"/>
						</svg>
					)}
					{exp.iconType === 'telecom' && (
						<svg class="sector-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
							<rect x="20" y="28" width="8" height="16" rx="1" fill="currentColor"/>
							<path d="M24 24C28.4183 24 32 20.4183 32 16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.5"/>
							<path d="M24 24C19.5817 24 16 20.4183 16 16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.5"/>
							<path d="M24 18C34.4934 18 43 12.6274 43 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.3"/>
							<path d="M24 18C13.5066 18 5 12.6274 5 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.3"/>
							<circle cx="24" cy="10" r="4" fill="currentColor"/>
						</svg>
					)}
				</div>
				<div class="card-content">
					<div class="card-header">
						<div class="header-top">
							<h3 class="sector-name">{exp.sector}</h3>
							<span class="period">{exp.period}</span>
						</div>
						<p class="companies">{exp.companies}</p>
					</div>
					<p class="role">{exp.role}</p>
					<p class="description">{exp.description}</p>
					<div class="stack-tags">
						{exp.stack.map((tech) => (
							<span class="tag">{tech}</span>
						))}
					</div>
				</div>
			</div>
		))}
	</div>
</section>

<style>
	.section-header {
		margin-bottom: 1rem;
	}

	.section-title {
		font-size: 3rem;
		margin-bottom: 1rem;
		color: var(--color-text);
	}

	.title-accent {
		width: 80px;
		height: 4px;
		background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-accent-secondary) 100%);
		border-radius: 2px;
	}

	.section-description {
		color: var(--color-text-muted);
		font-size: 1.125rem;
		margin-bottom: 3rem;
	}

	.experience-timeline {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.experience-card {
		display: flex;
		gap: 1.5rem;
		background: var(--color-surface);
		border-radius: 12px;
		padding: 1.5rem;
		border: 1px solid var(--color-surface-light);
		transition: all 0.3s ease;
	}

	.experience-card:hover {
		border-color: var(--color-accent-secondary);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
		transform: translateX(4px);
	}

	.card-icon-wrapper {
		flex-shrink: 0;
		width: 56px;
		height: 56px;
		background: var(--color-bg);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-surface-light);
		transition: all 0.3s ease;
	}

	.experience-card:hover .card-icon-wrapper {
		background: var(--color-accent-secondary);
		border-color: var(--color-accent-secondary);
	}

	.sector-icon {
		width: 32px;
		height: 32px;
		color: var(--color-accent-secondary);
		transition: color 0.3s ease;
	}

	.experience-card:hover .sector-icon {
		color: var(--color-bg);
	}

	.card-content {
		flex: 1;
		min-width: 0;
	}

	.card-header {
		margin-bottom: 0.5rem;
	}

	.header-top {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.sector-name {
		font-size: 1.125rem;
		color: var(--color-text);
		font-family: var(--font-sans), sans-serif;
		font-weight: 600;
		margin: 0;
	}

	.period {
		font-size: 0.75rem;
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-weight: 600;
		white-space: nowrap;
	}

	.companies {
		font-size: 0.875rem;
		color: var(--color-text-muted);
		margin: 0.25rem 0 0;
	}

	.role {
		font-size: 0.9rem;
		color: var(--color-accent-secondary);
		margin: 0.5rem 0;
		font-weight: 500;
	}

	.description {
		color: var(--color-text-muted);
		line-height: 1.5;
		font-size: 0.875rem;
		margin: 0 0 0.75rem;
	}

	.stack-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.tag {
		font-size: 0.7rem;
		padding: 0.2rem 0.5rem;
		background: var(--color-bg);
		color: var(--color-text-muted);
		border-radius: 4px;
		border: 1px solid var(--color-surface-light);
		font-family: monospace;
	}

	.tag-more {
		color: var(--color-accent-secondary);
		border-color: var(--color-accent-secondary);
		opacity: 0.7;
	}

	@media (max-width: 768px) {
		.section-title {
			font-size: 2.5rem;
		}

		.experience-card {
			flex-direction: column;
			gap: 1rem;
		}

		.card-icon-wrapper {
			width: 48px;
			height: 48px;
		}

		.sector-icon {
			width: 28px;
			height: 28px;
		}

		.header-top {
			flex-direction: column;
			gap: 0.25rem;
		}

		.experience-card:hover {
			transform: none;
		}
	}
</style>
