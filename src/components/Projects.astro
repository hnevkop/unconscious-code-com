---
interface Project {
	title: string;
	url: string;
	description: string;
	tags: string[];
	color: string;
	iconType: 'trading' | 'consciousness';
}

const projects: Project[] = [
	{
		title: "Trade Dialer",
		url: "https://trade-dialer.com",
		description: "Global stock market hours and index tracker. Monitor 15+ exchanges worldwide with live countdowns, real-time index prices, and market status indicators.",
		tags: ["Finance", "Global Markets", "Real-time", "Free Tool"],
		color: "var(--color-accent)",
		iconType: "trading"
	},
	{
		title: "Unconscious.me",
		url: "https://unconscious.me",
		description: "Digital space exploring the intersection of AI, psychology, and the unconscious mind. An experimental journey into how technology can illuminate hidden aspects of human cognition.",
		tags: ["AI", "Psychology", "Unconscious", "Experimental"],
		color: "var(--color-accent-secondary)",
		iconType: "consciousness"
	}
];
---

<section id="projects">
	<div class="section-header">
		<h2 class="section-title">Side Projects</h2>
		<div class="title-accent"></div>
	</div>
	<p class="section-description">
		Personal ventures and experiments that push creative and technical boundaries
	</p>
	<div class="projects-list">
		{projects.map((project) => (
			<div class="project-card" style={`--card-color: ${project.color}`}>
				<a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link">
					<div class="project-icon">
						{project.iconType === 'trading' && (
							<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M8 36L18 24L26 30L40 12" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
								<path d="M32 12H40V20" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
								<path d="M8 8V40H40" stroke="currentColor" stroke-width="2" opacity="0.4"/>
							</svg>
						)}
						{project.iconType === 'consciousness' && (
							<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
								<circle cx="24" cy="24" r="16" stroke="currentColor" stroke-width="2" opacity="0.3"/>
								<circle cx="24" cy="24" r="10" stroke="currentColor" stroke-width="2" opacity="0.5"/>
								<circle cx="24" cy="24" r="4" fill="currentColor"/>
								<path d="M24 4V12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
								<path d="M24 36V44" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
								<path d="M4 24H12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
								<path d="M36 24H44" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
							</svg>
						)}
					</div>
					<div class="project-content">
						<div class="project-header">
							<h3 class="project-title">{project.title}</h3>
							<svg class="external-link" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>
						<p class="project-description">{project.description}</p>
						<div class="project-tags">
							{project.tags.map((tag) => (
								<span class="tag" style={`--tag-color: ${project.color}`}>{tag}</span>
							))}
						</div>
					</div>
				</a>
			</div>
		))}
	</div>
</section>

<style>
	.section-header {
		margin-bottom: 1rem;
	}

	.section-title {
		font-size: 3rem;
		margin-bottom: 1rem;
		color: var(--color-text);
	}

	.title-accent {
		width: 80px;
		height: 4px;
		background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-accent-secondary) 100%);
		border-radius: 2px;
	}

	.section-description {
		color: var(--color-text-muted);
		font-size: 1.125rem;
		margin-bottom: 4rem;
	}

	.projects-list {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.project-card {
		background: var(--color-surface);
		border-radius: 20px;
		border: 1px solid var(--color-surface-light);
		overflow: hidden;
		transition: all 0.3s ease;
	}

	.project-card:hover {
		border-color: var(--card-color);
		transform: translateX(10px);
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
	}

	.project-link {
		text-decoration: none;
		color: inherit;
		display: flex;
		gap: 0;
	}

	.project-icon {
		flex-shrink: 0;
		width: 120px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--color-bg);
		border-right: 1px solid var(--color-surface-light);
		transition: all 0.3s ease;
	}

	.project-icon svg {
		width: 48px;
		height: 48px;
		color: var(--card-color);
		transition: all 0.3s ease;
	}

	.project-card:hover .project-icon {
		background: var(--card-color);
	}

	.project-card:hover .project-icon svg {
		color: var(--color-bg);
		transform: scale(1.1);
	}

	.project-content {
		padding: 2rem;
		flex: 1;
	}

	.project-header {
		display: flex;
		justify-content: space-between;
		align-items: start;
		margin-bottom: 1rem;
	}

	.project-title {
		font-size: 1.75rem;
		color: var(--color-text);
		font-family: var(--font-display), serif;
		margin: 0;
	}

	.external-link {
		color: var(--color-accent-secondary);
		transition: transform 0.3s ease;
		flex-shrink: 0;
	}

	.project-link:hover .external-link {
		transform: translate(4px, -4px);
	}

	.project-description {
		color: var(--color-text-muted);
		line-height: 1.7;
		margin-bottom: 1.5rem;
		font-size: 1.05rem;
	}

	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.tag {
		padding: 0.5rem 1rem;
		background: var(--color-surface-light);
		border-radius: 20px;
		font-size: 0.875rem;
		color: var(--tag-color);
		border: 1px solid var(--tag-color);
		transition: all 0.3s ease;
	}

	.project-card:hover .tag {
		background: var(--tag-color);
		color: var(--color-bg);
	}

	@media (max-width: 768px) {
		.section-title {
			font-size: 2.5rem;
		}

		.project-link {
			flex-direction: column;
		}

		.project-icon {
			width: 100%;
			height: 80px;
			border-right: none;
			border-bottom: 1px solid var(--color-surface-light);
		}

		.project-icon svg {
			width: 40px;
			height: 40px;
		}

		.project-content {
			padding: 1.5rem;
		}

		.project-title {
			font-size: 1.5rem;
		}

		.project-card:hover {
			transform: translateX(0);
		}
	}
</style>
