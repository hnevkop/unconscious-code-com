<section id="contact">
	<div class="contact-container">
		<div class="contact-content">
			<h2 class="contact-title">Let's Create Something Amazing</h2>
			<p class="contact-description">
				Whether you have a project in mind, need technical expertise, or just want to discuss
				ideas over coffee, I'd love to hear from you.
			</p>
			<div class="contact-methods">
				<a href="mailto:hnevkovsky@unconscious-code.com" class="contact-card email">
					<div class="card-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							<polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</div>
					<div class="card-info">
						<span class="card-label">Email</span>
						<span class="card-value">hnevkovsky@unconscious-code.com</span>
					</div>
				</a>
				<a href="https://twitter.com/hnevkop" target="_blank" rel="noopener noreferrer" class="contact-card twitter">
					<div class="card-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</div>
					<div class="card-info">
						<span class="card-label">X (Twitter)</span>
						<span class="card-value">@hnevkop</span>
					</div>
				</a>
				<a href="https://www.linkedin.com/in/hnevkovsky/" target="_blank" rel="noopener noreferrer" class="contact-card linkedin">
					<div class="card-icon">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							<circle cx="4" cy="4" r="2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</div>
					<div class="card-info">
						<span class="card-label">LinkedIn</span>
						<span class="card-value">Přemysl Hněvkovský</span>
					</div>
				</a>
			</div>
		</div>
		<div class="contact-visual">
			<div class="visual-element">
				<div class="floating-shape shape-1"></div>
				<div class="floating-shape shape-2"></div>
				<div class="floating-shape shape-3"></div>
			</div>
		</div>
	</div>
	<footer class="footer">
		<p>&copy; 2026 Přemysl Hněvkovský. Built with passion and precision.</p>
		<p class="footer-domain">unconscious-code.com</p>
	</footer>
</section>

<style>
	#contact {
		background: var(--color-surface);
		border-radius: 40px 40px 0 0;
		position: relative;
	}

	.contact-container {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.contact-title {
		font-size: 3.5rem;
		font-family: var(--font-display);
		color: var(--color-text);
		margin-bottom: 1.5rem;
		line-height: 1.2;
	}

	.contact-description {
		font-size: 1.125rem;
		color: var(--color-text-muted);
		line-height: 1.8;
		margin-bottom: 3rem;
	}

	.contact-methods {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.contact-card {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		padding: 1.5rem;
		background: var(--color-bg);
		border-radius: 16px;
		border: 1px solid var(--color-surface-light);
		text-decoration: none;
		color: inherit;
		transition: all 0.3s ease;
	}

	.contact-card:hover {
		transform: translateX(10px);
		border-color: var(--color-accent-secondary);
	}

	.card-icon {
		width: 60px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 12px;
		background: var(--color-surface-light);
		color: var(--color-accent-secondary);
		flex-shrink: 0;
		transition: all 0.3s ease;
	}

	.contact-card:hover .card-icon {
		background: var(--color-accent-secondary);
		color: var(--color-bg);
		transform: rotate(5deg) scale(1.05);
	}

	.card-info {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.card-label {
		font-size: 0.875rem;
		color: var(--color-text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.card-value {
		font-size: 1rem;
		color: var(--color-text);
		font-weight: 500;
	}

	.contact-visual {
		position: relative;
		height: 400px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.visual-element {
		position: relative;
		width: 300px;
		height: 300px;
	}

	.floating-shape {
		position: absolute;
		border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
		animation: morph 8s ease-in-out infinite;
	}

	.shape-1 {
		width: 200px;
		height: 200px;
		background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-tertiary) 100%);
		opacity: 0.2;
		top: 0;
		left: 0;
		animation-delay: 0s;
	}

	.shape-2 {
		width: 150px;
		height: 150px;
		background: linear-gradient(135deg, var(--color-accent-secondary) 0%, var(--color-accent) 100%);
		opacity: 0.2;
		bottom: 0;
		right: 0;
		animation-delay: 2s;
	}

	.shape-3 {
		width: 180px;
		height: 180px;
		background: linear-gradient(135deg, var(--color-accent-tertiary) 0%, var(--color-accent-secondary) 100%);
		opacity: 0.15;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		animation-delay: 4s;
	}

	@keyframes morph {
		0%, 100% {
			border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
			transform: rotate(0deg) scale(1);
		}
		25% {
			border-radius: 58% 42% 75% 25% / 76% 46% 54% 24%;
		}
		50% {
			border-radius: 50% 50% 33% 67% / 55% 27% 73% 45%;
			transform: rotate(180deg) scale(1.1);
		}
		75% {
			border-radius: 33% 67% 58% 42% / 63% 68% 32% 37%;
		}
	}

	.footer {
		margin-top: 6rem;
		padding-top: 3rem;
		border-top: 1px solid var(--color-surface-light);
		text-align: center;
	}

	.footer p {
		color: var(--color-text-muted);
		font-size: 0.95rem;
		margin: 0.5rem 0;
	}

	.footer-domain {
		color: var(--color-accent-secondary);
		font-weight: 500;
	}

	@media (max-width: 768px) {
		.contact-container {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.contact-title {
			font-size: 2.5rem;
		}

		.contact-visual {
			height: 300px;
		}

		.visual-element {
			width: 250px;
			height: 250px;
		}

		.contact-card {
			padding: 1.25rem;
		}

		.card-icon {
			width: 50px;
			height: 50px;
		}

		.contact-card:hover {
			transform: translateX(0);
		}
	}
</style>
